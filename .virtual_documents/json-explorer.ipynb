def extract_scan_info(d):
    out_dir = {}
    if 'comment' in d.keys():
        out_dir['comment'] = d['comment']
    else:
        out_dir['comment'] = ''
    for key in keys:
        out_dir[key] = d['scientificMetadata'][key]['value']
    return out_dir

out_list = [out_d for out_d in map(lambda d:extract_scan_info(d), js)]

    



